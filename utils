def get_log_channel(guild):
    for ch in guild.text_channels:
        if LOG_CHANNEL in ch.name or "logs" in ch.name.lower():
            return ch
    return None

def get_channel_by_name(guild, name):
    for ch in guild.text_channels:
        if name.lower().replace("・", "") in ch.name.lower().replace("・", ""):
            return ch
    return None

